# Configuration générale
PROJECT_NAME="Système de Gestion des Prêts Immobiliers"
VERSION="1.0.0"

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pret_user
POSTGRES_PASSWORD=pret_password
POSTGRES_DB=pret_immobilier

# Services Ports
SERVICE_DEMANDES_PORT=8001
SERVICE_CREDIT_PORT=8002
SERVICE_EVALUATION_PORT=8003
SERVICE_DECISION_PORT=8004
SERVICE_NOTIFICATION_PORT=8005

# Logs
LOG_LEVEL=INFO
